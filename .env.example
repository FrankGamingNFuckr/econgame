# EconGame Environment Variables
# Copy this file to .env and fill in your values

# ===== REQUIRED FOR PRODUCTION =====

# Flask secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=your-super-secret-random-key-here-change-me

# Flask environment (development or production)
FLASK_ENV=production

# Application URL (your domain)
APP_URL=https://yourdomain.com


# ===== OPTIONAL: EMAIL CONFIGURATION =====

# SMTP server for sending password reset emails
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Your email address and app password
# For Gmail: https://support.google.com/accounts/answer/185833
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here


# ===== OPTIONAL: DATABASE CONFIGURATION =====

# If using PostgreSQL instead of JSON files
# DATABASE_URL=postgresql://username:password@host:port/database


# ===== OPTIONAL: SENDGRID CONFIGURATION =====

# Alternative to SMTP for sending emails
# SENDGRID_API_KEY=your-sendgrid-api-key-here
